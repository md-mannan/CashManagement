# Cash Management System - Production Environment Configuration

# Application Settings
APP_NAME="Cash Management"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=http://localhost/cash-management
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Database Configuration for XAMPP
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cash_management
DB_USERNAME=root
DB_PASSWORD=

# Cache and Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=sync

# Cache and Session
CACHE_STORE=file
# CACHE_PREFIX=

# Mail Configuration (using XAMPP's Mercury)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@cashmanagement.local"
MAIL_FROM_NAME="${APP_NAME}"

# Currency Settings
DEFAULT_CURRENCY=USD
SECONDARY_CURRENCY=EUR
ENABLE_NOTIFICATIONS=true
ENABLE_ACTIVITY_LOGGING=true
ENABLE_BACKUP=false
ENABLE_SOCIAL_LOGIN=false

# Exchange Rate API
EXCHANGE_RATE_API_KEY=your_api_key_here
EXCHANGE_RATE_API_PROVIDER=exchangerate-api.com

# Security
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# File Storage
FILESYSTEM_DISK=local

# Installation Flag (Set to true after installation)
APP_INSTALLED=false

# Performance Settings
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# Application Specific
CASH_MANAGEMENT_VERSION=2.0.0
ENABLE_NOTIFICATIONS=true
ENABLE_ACTIVITY_LOGGING=true
ENABLE_BACKUP=false
ENABLE_SOCIAL_LOGIN=false

# Default Currencies
DEFAULT_CURRENCY=USD
SECONDARY_CURRENCY=EUR

# Installation Status
APP_INSTALLED=false
