# Local Development Environment Configuration
# Copy this file to .env for local development

# Application Configuration
APP_NAME="Cash Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Logging Configuration
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cashmanagement_local
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Cache Configuration
CACHE_STORE=file
CACHE_PREFIX=cashmanagement_local

# Redis Configuration (Optional for local)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Queue Configuration
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids

# Mail Configuration (Local Testing)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting Configuration (WebSockets)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=local_app_id
REVERB_APP_KEY=local_app_key
REVERB_APP_SECRET=local_app_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Filesystem Configuration
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Social Authentication (Local Testing - Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Security Configuration (Relaxed for Local)
FORCE_HTTPS=false
HSTS_MAX_AGE=0
CONTENT_SECURITY_POLICY=false

# Performance Configuration
AUTO_DETECT_ENVIRONMENT=true
AUTO_MIGRATE=true
AUTO_SEED=true

# Backup Configuration (Disabled for Local)
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=7

# Monitoring and Analytics (Disabled for Local)
ERROR_TRACKING_ENABLED=false
PERFORMANCE_MONITORING=false

# Exchange Rate API (Optional)
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_UPDATE_INTERVAL=3600

# Local Development Optimizations
OPTIMIZE_AUTOLOADER=false
VIEW_CACHE_ENABLED=false
ROUTE_CACHE_ENABLED=false
CONFIG_CACHE_ENABLED=false

# Development Tools
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# Vite Configuration (for local development)
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
