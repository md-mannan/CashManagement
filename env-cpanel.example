# cPanel Production Environment Configuration
# Copy this file to .env and update the values for your cPanel hosting

# Application Configuration
APP_NAME="Cash Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

# Logging Configuration
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration (cPanel MySQL)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_database_name
DB_USERNAME=your_cpanel_database_user
DB_PASSWORD=your_cpanel_database_password

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Cache Configuration (use file cache for shared hosting)
CACHE_STORE=file
CACHE_PREFIX=cashmanagement_prod

# Queue Configuration (use database for shared hosting)
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# Mail Configuration (cPanel SMTP)
MAIL_MAILER=smtp
MAIL_HOST=yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting Configuration (optional - disable if not needed)
BROADCAST_CONNECTION=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

# Filesystem Configuration
FILESYSTEM_DISK=public

# Security Configuration
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000
CONTENT_SECURITY_POLICY=true

# Performance Configuration
AUTO_DETECT_ENVIRONMENT=true
AUTO_MIGRATE=false
AUTO_SEED=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# Monitoring and Analytics
ERROR_TRACKING_ENABLED=false
PERFORMANCE_MONITORING=false

# Exchange Rate API (Optional)
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_UPDATE_INTERVAL=3600

# Production Optimizations
OPTIMIZE_AUTOLOADER=true
VIEW_CACHE_ENABLED=true
ROUTE_CACHE_ENABLED=true
CONFIG_CACHE_ENABLED=true

# cPanel Specific Settings
CPANEL_COMPATIBILITY=true
SHARED_HOSTING_MODE=true